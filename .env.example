# Database
DATABASE_URL=
DIRECT_URL=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App
# Use localhost only for local development. Production values must use the canonical HTTPS origin.
APP_BASE_URL=https://justjournalit.vercel.app
NEXT_PUBLIC_APP_URL=https://justjournalit.vercel.app
NEXT_PUBLIC_SITE_URL=https://justjournalit.vercel.app
ADMIN_EMAIL=
# Required in production. Use a high-entropy value with at least 32 characters.
CRON_SECRET=

# NextAuth
NEXTAUTH_URL=https://justjournalit.vercel.app
NEXTAUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Rate Limiting
ALLOW_IN_MEMORY_RATE_LIMITS_IN_PRODUCTION=false

# NOWPayments
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_PUBLIC_KEY=
# Required when payments are configured in production. Use at least 32 characters.
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_API_BASE_URL=https://api.nowpayments.io/v1
NOWPAYMENTS_SUCCESS_URL=https://justjournalit.vercel.app/subscribe/success
NOWPAYMENTS_CANCEL_URL=https://justjournalit.vercel.app/subscribe/cancelled
NOWPAYMENTS_IPN_CALLBACK_URL=https://justjournalit.vercel.app/api/v1/payments/webhook

# Subscription
SUBSCRIPTION_PRICE_USD=10
SUBSCRIPTION_BILLING_INTERVAL=month
SUBSCRIPTION_GRACE_DAYS=3

XAI_API_KEY=
XAI_BASE_URL=
XAI_MODEL=

# Upstash Redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Inngest Background Jobs
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Sentry Error Tracking
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Direct Account Sync Integrations
# Tradovate OAuth Settings
TRADOVATE_CLIENT_ID=
TRADOVATE_CLIENT_SECRET=
TRADOVATE_REDIRECT_URI=https://justjournalit.vercel.app/dashboard/import

# DxFeed Credentials Sync Settings
DXFEED_AUTH_URL=
DXFEED_PLATFORM_KEY=
DXFEED_ENVIRONMENT=1
DXFEED_HISTORY_LOOKBACK_DAYS=364

# Rithmic WebSocket Bridge API URL
NEXT_PUBLIC_RITHMIC_API_URL=

