generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["public"]
}

model Account {
  id                     String                   @id @default(cuid())
  number                 String
  name                   String?
  broker                 String?
  startingBalance        Float                    @default(0)
  userId                 String
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  isArchived             Boolean                  @default(false)
  isConfigured           Boolean                  @default(false)
  User                   User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  DailyNote              DailyNote[]
  LiveAccountTransaction LiveAccountTransaction[]
  Trade                  Trade[]

  @@unique([number, userId])
  @@index([userId])
  @@schema("public")
}

model BacktestTrade {
  id               String            @id @default(cuid())
  userId           String
  pair             String
  direction        BacktestDirection
  outcome          BacktestOutcome
  session          BacktestSession
  model            BacktestModel
  customModel      String?
  riskRewardRatio  Float
  entryPrice       Float
  stopLoss         Float
  takeProfit       Float
  exitPrice        Float
  pnl              Float
  imageOne         String?
  imageTwo         String?
  imageThree       String?
  imageFour        String?
  imageFive        String?
  imageSix         String?
  cardPreviewImage String?
  notes            String?
  tags             String[]
  dateExecuted     DateTime
  backtestDate     DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime
  riskPoints       Float             @default(0)
  rewardPoints     Float             @default(0)
  User             User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, pair, dateExecuted, entryPrice, direction])
  @@index([userId, model])
  @@schema("public")
}

model BreachRecord {
  id                String       @id @default(cuid())
  phaseAccountId    String
  breachType        BreachType
  breachAmount      Float
  breachTime        DateTime     @default(now())
  currentEquity     Float
  accountSize       Float
  dailyStartBalance Float?
  highWaterMark     Float?
  tradeId           String?
  notes             String?
  updatedAt         DateTime     @updatedAt
  PhaseAccount      PhaseAccount @relation(fields: [phaseAccountId], references: [id], onDelete: Cascade)

  @@index([phaseAccountId])
  @@schema("public")
}

model DailyAnchor {
  id             String       @id @default(cuid())
  phaseAccountId String
  date           DateTime     @db.Date
  anchorEquity   Float
  computedAt     DateTime     @default(now())
  PhaseAccount   PhaseAccount @relation(fields: [phaseAccountId], references: [id], onDelete: Cascade)

  @@unique([phaseAccountId, date])
  @@index([date])
  @@schema("public")
}

model DailyNote {
  id        String          @id @default(cuid())
  userId    String
  date      DateTime        @db.Date
  note      String
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  accountId String?
  emotion   JournalEmotion?
  Account   Account?        @relation(fields: [accountId], references: [id], onDelete: Cascade)
  User      User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, accountId, date])
  @@index([accountId])
  @@schema("public")
}

model DashboardTemplate {
  id        String   @id @default(cuid())
  userId    String
  name      String
  isDefault Boolean  @default(false)
  isActive  Boolean  @default(false)
  layout    Json     @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
  @@index([userId, isActive])
  @@index([userId, isDefault])
  @@schema("public")
}

model AdminWidgetSetting {
  id          String   @id @default(cuid())
  widgetType  String   @unique
  label       String?
  description String?
  visible     Boolean  @default(true)
  recommended Boolean  @default(false)
  deprecated  Boolean  @default(false)
  status      String   @default("stable")
  premiumOnly Boolean  @default(false)
  roleGate    String?
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([visible])
  @@index([recommended])
  @@index([deprecated])
  @@schema("public")
}

model AdminDashboardPreset {
  id          String   @id @default(cuid())
  name        String   @unique
  segment     String   @default("all")
  description String?
  layout      Json     @default("[]")
  active      Boolean  @default(true)
  recommended Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([segment])
  @@index([active])
  @@index([recommended])
  @@schema("public")
}

model AdminFeatureFlag {
  id           String   @id @default(cuid())
  key          String   @unique
  label        String
  description  String?
  enabled      Boolean  @default(false)
  internalOnly Boolean  @default(false)
  roleGate     String?
  cohort       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([enabled])
  @@index([internalOnly])
  @@schema("public")
}

model AdminSharingPolicy {
  id                     String   @id @default(cuid())
  key                    String   @unique @default("default")
  publicSharingEnabled    Boolean  @default(true)
  defaultExpirationDays   Int?
  requireExpiration       Boolean  @default(false)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@schema("public")
}

model LiveAccountTransaction {
  id          String          @id @default(cuid())
  accountId   String
  userId      String
  type        TransactionType
  amount      Float
  description String?
  createdAt   DateTime        @default(now())
  Account     Account         @relation(fields: [accountId], references: [id], onDelete: Cascade)
  User        User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([accountId, createdAt])
  @@index([userId])
  @@schema("public")
}

model MasterAccount {
  id             String              @id @default(cuid())
  userId         String
  accountName    String
  propFirmName   String
  accountSize    Float
  evaluationType String
  currentPhase   Int
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @default(now()) @updatedAt
  status         MasterAccountStatus @default(active)
  isArchived     Boolean             @default(false)
  User           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  Payout         Payout[]
  PhaseAccount   PhaseAccount[]

  @@unique([userId, accountName])
  @@index([userId, status])
  @@schema("public")
}

model Payout {
  id              String        @id @default(cuid())
  masterAccountId String
  phaseAccountId  String
  amount          Float
  status          PayoutStatus  @default(pending)
  requestDate     DateTime      @default(now())
  approvedDate    DateTime?
  paidDate        DateTime?
  rejectedDate    DateTime?
  notes           String?
  rejectionReason String?
  updatedAt       DateTime      @updatedAt
  MasterAccount   MasterAccount @relation(fields: [masterAccountId], references: [id], onDelete: Cascade)
  PhaseAccount    PhaseAccount  @relation(fields: [phaseAccountId], references: [id], onDelete: Cascade)

  @@index([masterAccountId])
  @@index([phaseAccountId])
  @@schema("public")
}

model PhaseAccount {
  id                     String             @id @default(cuid())
  masterAccountId        String
  phaseNumber            Int
  phaseId                String?
  accountSize            Float?
  status                 PhaseAccountStatus @default(active)
  profitTargetPercent    Float
  dailyDrawdownPercent   Float
  maxDrawdownPercent     Float
  maxDrawdownType        DrawdownType       @default(static)
  minTradingDays         Int                @default(0)
  timeLimitDays          Int?
  consistencyRulePercent Float              @default(0)
  profitSplitPercent     Float?
  payoutCycleDays        Int?
  minProfitForPayout     Float? // Min profit (in $) required to request payout (funded phases only)
  startDate              DateTime           @default(now())
  endDate                DateTime?
  updatedAt              DateTime           @default(now()) @updatedAt
  BreachRecord           BreachRecord[]
  DailyAnchor            DailyAnchor[]
  Payout                 Payout[]
  MasterAccount          MasterAccount      @relation(fields: [masterAccountId], references: [id], onDelete: Cascade)
  Trade                  Trade[]

  @@unique([masterAccountId, phaseNumber])
  @@index([masterAccountId])
  @@index([masterAccountId, phaseNumber])
  @@index([masterAccountId, status])
  @@index([phaseId])
  @@index([status])
  @@schema("public")
}

model Trade {
  id                   String           @id @default(cuid())
  accountNumber        String
  quantity             Float            @default(0)
  entryId              String?
  closeId              String?
  tradeIdentityKey     String?
  instrument           String
  entryPrice           String
  closePrice           String
  entryDate            String
  closeDate            String
  entryPriceValue      Float?
  closePriceValue      Float?
  pnl                  Float
  timeInPosition       Float            @default(0)
  userId               String
  side                 String?
  commission           Float            @default(0)
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @default(now()) @updatedAt
  comment              String?
  groupId              String?
  cardPreviewImage     String?
  cardPreviewTransform Json?
  imageOne             String?
  imageTwo             String?
  imageThree           String?
  imageFour            String?
  imageFive            String?
  imageSix             String?
  accountId            String?
  phaseAccountId       String?
  symbol               String?
  entryTime            DateTime?
  exitTime             DateTime?
  closeReason          String?
  stopLoss             String?
  stopLossValue        Float?
  takeProfit           String?
  takeProfitValue      Float?
  tags                 String[]
  marketBias           MarketBias?
  modelId              String?
  selectedRules        Json?
  outcome              TradeOutcome?
  ruleBroken           Boolean?         @default(false)
  newsDay              Boolean?         @default(false)
  selectedNews         String?
  newsTraded           Boolean?         @default(false)
  biasTimeframe        String?
  narrativeTimeframe   String?
  entryTimeframe       String?
  structureTimeframe   String?
  orderType            String?
  chartLinks           String?
  chartLinksList       String[]         @default([])
  plannedEntry         String?
  plannedStopLoss      String?
  plannedTakeProfit    String?
  plannedSize          Float?
  planNotes            String?
  mae                  Float?
  mfe                  Float?
  Account              Account?         @relation(fields: [accountId], references: [id], onDelete: Cascade)
  TradingModel         TradingModel?    @relation(fields: [modelId], references: [id])
  setup                String?
  PhaseAccount         PhaseAccount?    @relation(fields: [phaseAccountId], references: [id], onDelete: Cascade)
  executions           TradeExecution[]

  @@unique([userId, tradeIdentityKey], name: "trade_identity_key")
  @@index([accountId, exitTime])
  @@index([accountId, phaseAccountId])
  @@index([accountNumber])
  @@index([entryId])
  @@index([exitTime])
  @@index([groupId])
  @@index([modelId])
  @@index([phaseAccountId, exitTime])
  @@index([symbol])
  @@index([tradeIdentityKey])
  @@index([userId, accountNumber, id])
  @@index([userId, entryDate(sort: Desc)])
  @@index([userId, accountId, entryDate(sort: Desc)])
  @@index([userId, phaseAccountId, entryDate(sort: Desc)])
  @@index([userId, entryId])
  @@index([userId, modelId, entryDate(sort: Desc)])
  @@index([userId, ruleBroken, entryDate(sort: Desc)])
  @@index([userId, outcome, entryDate(sort: Desc)])
  // Composite indexes for server-side filtering (/api/v1/trades)
  @@index([userId, instrument])
  @@index([userId, accountNumber, entryDate])
  @@index([userId, pnl])
  @@schema("public")
}

model TradeExecution {
  id                  String             @id @default(cuid())
  tradeId             String
  userId              String
  kind                TradeExecutionKind
  quantity            Float              @default(0)
  price               Float?
  executedAt          DateTime?
  pnl                 Float              @default(0)
  commission          Float              @default(0)
  brokerExecutionId   String?
  legacySourceTradeId String?
  closeReason         String?
  rawSymbol           String?
  metadata            Json?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  Trade               Trade              @relation(fields: [tradeId], references: [id], onDelete: Cascade)

  @@unique([tradeId, kind, legacySourceTradeId], name: "trade_execution_legacy_source_key")
  @@index([tradeId, kind])
  @@index([tradeId, executedAt])
  @@index([userId, brokerExecutionId])
  @@schema("public")
}

model TradeTag {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("#3b82f6")
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([name, userId])
  @@index([userId])
  @@schema("public")
}

model TradingModel {
  id        String   @id @default(cuid())
  userId    String
  name      String
  rules     Json     @default("[]")
  setups    Json     @default("[]")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  Trade     Trade[]

  @@unique([userId, name])
  @@index([userId])
  @@schema("public")
}

model User {
  id                     String                   @id
  email                  String                   @unique
  auth_user_id           String                   @unique
  isFirstConnection      Boolean                  @default(true)
  firstName              String?
  lastName               String?
  role                   UserRole                 @default(user)
  onboardingStatus       Json?                    @map("onboarding_status")
  Account                Account[]
  BacktestTrade          BacktestTrade[]
  DailyNote              DailyNote[]
  DashboardTemplate      DashboardTemplate[]
  LiveAccountTransaction LiveAccountTransaction[]
  MasterAccount          MasterAccount[]
  Notification           Notification[]
  ImportJob              ImportJob[]
  Feedback               Feedback[]
  UserGeoLog             UserGeoLog[]
  TradeTag               TradeTag[]
  TradingModel           TradingModel[]
  WeeklyReview           WeeklyReview[]
  WeeklyAIReview         WeeklyAIReview[]
  ActivityLog            ActivityLog[]
  JournalTemplate        JournalTemplate[]
  UserGoal               UserGoal[]
  SharedReport           SharedReport[]
  settings               UserSettings?
  Subscription           Subscription?
  AIChat                 AIChat[]
  AISavedInsight         AISavedInsight[]
  etpToken               String?
  thorToken              String?
  fcmToken               String?
  synchronizations       Synchronization[]

  @@index([auth_user_id])
  @@index([email])
  @@schema("public")
}

model JournalTemplate {
  id        String   @id @default(cuid())
  userId    String
  name      String
  content   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId, createdAt])
  @@schema("public")
}

model UserSettings {
  userId                String   @id
  timezone              String   @default("America/New_York")
  theme                 String   @default("system")
  accountFilterSettings String?
  aiSettings            Json?
  backtestInputMode     String   @default("manual")
  breakEvenThreshold    Float    @default(10)
  pnlDisplayMode        String   @default("net")
  accentPack            String   @default("classic")
  widgetStyle           String   @default("default")
  chartStyle            String   @default("smooth")
  autoAdjustAccountDate Boolean  @default(false)
  webhookToken          String?  @unique
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  User                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@schema("public")
}

model ImportJob {
  id              String          @id @default(cuid())
  userId          String
  status          ImportJobStatus @default(queued)
  stage           String          @default("queued")
  progress        Int             @default(0)
  totalItems      Int             @default(0)
  processedItems  Int             @default(0)
  importedCount   Int             @default(0)
  skippedCount    Int             @default(0)
  fileName        String
  fileSize        Int
  fileData        Bytes
  state           Json?
  error           String?
  cancelRequested Boolean         @default(false)
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  User            User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, status])
  @@schema("public")
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  action    String // e.g. TRADE_CREATED, ACCOUNT_RENAMED, BACKUP_RESTORED
  entity    String // e.g. Trade, Account, Profile
  entityId  String? // ID of affected resource (nullable for bulk ops)
  metadata  Json? // Additional context (old/new values, counts, etc.)
  ipAddress String?
  createdAt DateTime @default(now())
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([action])
  @@schema("public")
}

model Notification {
  id              String               @id @default(uuid())
  userId          String
  type            NotificationType
  title           String
  message         String
  data            Json?
  isRead          Boolean              @default(false)
  actionRequired  Boolean              @default(false)
  invalidationKey String? // Smart deduplication key
  priority        NotificationPriority @default(MEDIUM)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  User            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, actionRequired])
  @@index([userId, invalidationKey]) // Fast lookup for smart invalidation
  @@schema("public")
}

model WeeklyReview {
  id            String             @id @default(cuid())
  userId        String
  startDate     DateTime           @db.Date
  endDate       DateTime           @db.Date
  calendarImage String?
  expectation   WeeklyExpectation?
  actualOutcome WeeklyExpectation?
  isCorrect     Boolean?
  notes         String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  User          User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, startDate])
  @@index([userId])
  @@schema("public")
}

enum BacktestDirection {
  BUY
  SELL

  @@schema("public")
}

enum BacktestModel {
  ICT_2022
  MSNR
  TTFM
  PRICE_ACTION
  SUPPLY_DEMAND
  SMART_MONEY
  CUSTOM

  @@schema("public")
}

enum BacktestOutcome {
  WIN
  LOSS
  BREAKEVEN

  @@schema("public")
}

enum BacktestSession {
  ASIAN
  LONDON
  NEW_YORK

  @@schema("public")
}

enum BreachType {
  daily_drawdown
  max_drawdown

  @@schema("public")
}

enum DrawdownType {
  static
  trailing

  @@schema("public")
}

enum MarketBias {
  BULLISH
  BEARISH
  UNDECIDED

  @@schema("public")
}

enum MasterAccountStatus {
  active
  funded
  failed

  @@schema("public")
}

enum PayoutStatus {
  pending
  approved
  paid
  rejected

  @@schema("public")
}

enum NotificationPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL

  @@schema("public")
}

enum NotificationType {
  FUNDED_PENDING_APPROVAL
  FUNDED_APPROVED
  FUNDED_DECLINED
  PHASE_TRANSITION_PENDING // Waiting for user to enter next phase ID
  PAYOUT_APPROVED
  PAYOUT_REJECTED
  SYSTEM
  RISK_ALERT
  IMPORT_STATUS
  WEEKLY_PERFORMANCE
  STRATEGY_DEVIATION
  SYSTEM_ANNOUNCEMENT
  TRADE_STATUS

  // Granular risk alert types for smart invalidation
  RISK_DAILY_LOSS_80 // Daily loss limit at 80%
  RISK_DAILY_LOSS_95 // Daily loss limit at 95%
  RISK_MAX_DRAWDOWN_80 // Max drawdown at 80%
  RISK_MAX_DRAWDOWN_95 // Max drawdown at 95%

  // Import lifecycle tracking
  IMPORT_PROCESSING // Import in progress
  IMPORT_COMPLETE // Import finished

  // Strategy compliance
  STRATEGY_SESSION_VIOLATION // Trade outside allowed sessions

  // Admin feedback reply
  FEEDBACK_REPLY // Admin replied to user feedback

  // Subscription & Payment lifecycle
  PAYMENT_DUE_SOON           // Payment due in 3 or 1 days
  PAYMENT_DUE_TODAY          // Payment due today, invoice created
  PAYMENT_OVERDUE            // Past due, within grace period
  SUBSCRIPTION_EXPIRED       // Access revoked after grace period
  PAYMENT_RECEIVED           // Payment confirmed via IPN
  PAYMENT_FAILED             // Payment failed or expired
  ACCESS_RESTORED            // Access restored after payment
  ADMIN_FREE_ACCESS_GRANTED  // Admin granted free access
  ADMIN_FREE_ACCESS_REVOKED  // Admin revoked free access

  @@schema("public")
}

enum ImportJobStatus {
  queued
  processing
  completed
  failed
  cancelled

  @@schema("public")
}

enum PhaseAccountStatus {
  active
  passed
  failed
  archived
  pending
  pending_approval

  @@schema("public")
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL

  @@schema("public")
}

enum WeeklyExpectation {
  BULLISH_EXPANSION
  BEARISH_EXPANSION
  CONSOLIDATION

  @@schema("public")
}

enum UserRole {
  user
  admin

  @@schema("public")
}

enum TradeOutcome {
  GOOD_WIN
  BAD_WIN
  GOOD_BE
  BAD_BE
  BREAKEVEN
  GOOD_LOSS
  BAD_LOSS

  @@schema("public")
}

enum TradeExecutionKind {
  ENTRY
  EXIT

  @@schema("public")
}

enum JournalEmotion {
  confident
  anxious
  focused
  energetic
  calm
  frustrated
  optimistic
  pessimistic
  disciplined
  impulsive
  happy
  sad
  neutral
  tired
  excited
  stressed
  relaxed

  @@schema("public")
}

// =============================================
// FEEDBACK SYSTEM
// =============================================

model Feedback {
  id          String           @id @default(cuid())
  userId      String?
  name        String?
  email       String?
  category    FeedbackCategory
  subject     String
  message     String
  attachments Json? // Array of {url, name, size, type}
  status      FeedbackStatus   @default(OPEN)
  ipAddress   String?
  userAgent   String?
  country     String?
  city        String?
  region      String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  User        User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  Replies     FeedbackReply[]

  @@index([userId])
  @@index([status])
  @@index([category])
  @@index([createdAt])
  @@schema("public")
}

model FeedbackReply {
  id         String   @id @default(cuid())
  feedbackId String
  message    String
  createdAt  DateTime @default(now())
  Feedback   Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)

  @@index([feedbackId])
  @@schema("public")
}

enum FeedbackCategory {
  BUG_REPORT
  FEATURE_REQUEST
  GENERAL
  OTHER

  @@schema("public")
}

enum FeedbackStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED

  @@schema("public")
}

// =============================================
// DONATION CONFIGURATION
// =============================================

model DonationAddress {
  id        String   @id @default(cuid())
  token     String // e.g. "BTC", "ETH", "USDT"
  network   String // e.g. "Bitcoin", "ERC-20", "TRC-20"
  address   String
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@schema("public")
}

model SiteUiSettings {
  id                 String   @id
  showDonateButton   Boolean  @default(true)
  showFeedbackButton Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@schema("public")
}

// =============================================
// ERROR LOGGING
// =============================================

model ErrorLog {
  id        String      @id @default(cuid())
  source    ErrorSource
  level     ErrorLevel  @default(ERROR)
  message   String
  stack     String?
  url       String?
  userId    String?
  metadata  Json?
  ipAddress String?
  createdAt DateTime    @default(now())

  @@index([source])
  @@index([level])
  @@index([createdAt])
  @@index([userId])
  @@schema("public")
}

enum ErrorSource {
  CLIENT
  SERVER
  API

  @@schema("public")
}

enum ErrorLevel {
  WARNING
  ERROR
  CRITICAL

  @@schema("public")
}

// =============================================
// USER GEOLOCATION TRACKING
// =============================================

model UserGeoLog {
  id          String   @id @default(cuid())
  userId      String
  country     String?
  countryCode String?
  city        String?
  region      String?
  latitude    Float?
  longitude   Float?
  ipAddress   String?
  createdAt   DateTime @default(now())
  User        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([countryCode])
  @@index([createdAt])
  @@schema("public")
}

model WeeklyAIReview {
  id            String   @id @default(cuid())
  userId        String
  weekStart     DateTime @db.Date
  weekEnd       DateTime @db.Date
  summary       String   @db.Text
  highlights    Json     @default("[]")
  lowlights     Json     @default("[]")
  stats         Json     @default("{}")
  grade         String   @default("")
  focusNextWeek String?  @db.Text
  createdAt     DateTime @default(now())
  User          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStart])
  @@index([userId, createdAt])
  @@schema("public")
}

// =============================================
// GOAL TRACKING
// =============================================

model UserGoal {
  id          String    @id @default(cuid())
  userId      String
  title       String
  description String?
  metric      String    // "pnl" | "winRate" | "trades" | "streak" | "drawdown" | "custom"
  targetValue Float
  currentValue Float   @default(0)
  period      String    // "daily" | "weekly" | "monthly" | "all-time"
  startDate   DateTime
  endDate     DateTime?
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  User        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isCompleted])
  @@schema("public")
}

// =============================================
// SHAREABLE REPORTS
// =============================================

model SharedReport {
  id          String   @id @default(cuid())
  userId      String
  slug        String   @unique
  title       String   @default("Trading Report")
  dateFrom    String?
  dateTo      String?
  accountId   String?
  snapshot    Json
  isPublic    Boolean  @default(true)
  viewCount   Int      @default(0)
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  User        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@schema("public")
}

// =============================================
// SUBSCRIPTION & PAYMENT SYSTEM
// =============================================

enum SubscriptionStatus {
  active
  past_due
  unpaid
  expired
  cancelled
  free_access
  invited_free
  promo_active

  @@schema("public")
}

enum PaymentStatus {
  pending
  waiting
  confirming
  confirmed
  sending
  finished
  partially_paid
  failed
  refunded
  expired

  @@schema("public")
}

enum FreeAccessType {
  lifetime
  until_date
  one_time_signup

  @@schema("public")
}

enum PromoType {
  percentage_discount
  fixed_discount
  free_months
  lifetime_free

  @@schema("public")
}

enum PromoApplicability {
  signup_only
  renewal_only
  any

  @@schema("public")
}

model Subscription {
  id                 String             @id @default(cuid())
  userId             String             @unique
  status             SubscriptionStatus @default(unpaid)
  planId             String             @default("pro")
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  nextPaymentDue     DateTime?
  cancelledAt        DateTime?
  promoCodeId        String?
  freeAccessId       String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  User               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  PromoCode          PromoCode?         @relation(fields: [promoCodeId], references: [id])
  FreeAccess         FreeAccessInvite?  @relation(fields: [freeAccessId], references: [id])
  PaymentRecord      PaymentRecord[]

  @@index([status])
  @@index([nextPaymentDue])
  @@schema("public")
}

model PaymentRecord {
  id                      String    @id @default(cuid())
  userId                  String
  subscriptionId          String
  planId                  String    @default("pro")
  amountUsd               Float
  provider                String    @default("nowpayments")
  providerPaymentId       String?   @unique
  providerInvoiceId       String?   @unique
  providerStatus          String?
  payCurrency             String?
  payAmount               Float?
  paymentUrl              String?
  invoiceUrl              String?
  subscriptionPeriodStart DateTime?
  subscriptionPeriodEnd   DateTime?
  dueDate                 DateTime?
  paidAt                  DateTime?
  expiredAt               DateTime?
  rawProviderPayload      Json?
  promoCodeId             String?
  discountAmount          Float     @default(0)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  Subscription            Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  PromoCode               PromoCode?   @relation(fields: [promoCodeId], references: [id])

  @@index([userId])
  @@index([subscriptionId])
  @@index([dueDate])
  @@schema("public")
}

model PromoCode {
  id              String            @id @default(cuid())
  code            String            @unique
  type            PromoType
  applicability   PromoApplicability @default(signup_only)
  value           Float
  maxUses         Int?
  usesCount       Int               @default(0)
  validFrom       DateTime          @default(now())
  validUntil      DateTime?
  isActive        Boolean           @default(true)
  appliesToPlan   String            @default("pro")
  createdBy       String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  Subscription    Subscription[]
  PaymentRecord   PaymentRecord[]
  PromoRedemption PromoRedemption[]

  @@index([code])
  @@index([isActive])
  @@schema("public")
}

model PromoRedemption {
  id          String    @id @default(cuid())
  promoCodeId String
  userId      String
  redeemedAt  DateTime  @default(now())
  PromoCode   PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)

  @@unique([promoCodeId, userId])
  @@index([userId])
  @@schema("public")
}

model FreeAccessInvite {
  id               String         @id @default(cuid())
  email            String         @unique
  type             FreeAccessType
  expiresAt        DateTime?
  note             String?
  grantedBy        String?
  grantedAt        DateTime       @default(now())
  revokedAt        DateTime?
  isActive         Boolean        @default(true)
  registeredAt     DateTime?
  registeredUserId String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  Subscription     Subscription[]

  @@index([email])
  @@index([isActive])
  @@schema("public")
}

model AIChat {
  id           String           @id @default(cuid())
  userId       String
  title        String           @default("New Conversation")
  isPinned     Boolean          @default(false)
  isArchived   Boolean          @default(false)
  isDeleted    Boolean          @default(false)
  
  // Data Context Selection
  accounts     String[]         // Selected account IDs/numbers
  dateRange    String           // "last-7-days" | "last-30-days" | "last-90-days" | "custom"
  customFrom   DateTime?        // For custom range
  customTo     DateTime?        // For custom range
  dataSources  String[]         // e.g. ["trades", "journals", "reviews", ...]
  
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  
  User         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages     AIChatMessage[]

  @@index([userId, isPinned, isArchived, isDeleted])
  @@schema("public")
}

model AIChatMessage {
  id        String   @id @default(cuid())
  chatId    String
  role      String   // "user" | "assistant"
  content   String   @db.Text
  createdAt DateTime @default(now())
  
  Chat      AIChat   @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId, createdAt])
  @@schema("public")
}

model AISavedInsight {
  id          String   @id @default(cuid())
  userId      String
  title       String
  content     String   @db.Text
  category    String   @default("insight") // "insight" | "mistake" | "strategy"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  User        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@schema("public")
}

model AdminAISetting {
  id                         String   @id @default("global")
  enabled                    Boolean  @default(true)
  demoModeEnabled            Boolean  @default(true)
  freePlanAccess             Boolean  @default(false)
  paidPlanAccess             Boolean  @default(true)
  adminAccess                Boolean  @default(true)
  maxContextSize             Int      @default(32768)
  maxMessagesPerDay          Int      @default(50)
  maxTokensPerResponse       Int      @default(2048)
  conversationRetentionDays  Int      @default(30)
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  @@schema("public")
}

model AIChatUsageLog {
  id              String   @id @default(cuid())
  userId          String
  chatId          String?
  promptTokens    Int      @default(0)
  completionTokens Int     @default(0)
  totalTokens     Int      @default(0)
  estimatedCost   Float    @default(0)
  responseTimeMs  Int      @default(0)
  createdAt       DateTime @default(now())
  
  @@index([userId, createdAt])
  @@index([createdAt])
  @@schema("public")
}

model Synchronization {
  id               String    @id @default(uuid())
  userId           String
  service          String
  accountId        String
  lastSyncedAt     DateTime
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  token            String?
  tokenExpiresAt   DateTime?
  dailySyncTime    DateTime?
  includedFeeTypes Json?
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, service, accountId])
  @@index([userId])
  @@index([service])
  @@schema("public")
}

